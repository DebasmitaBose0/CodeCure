# CodeCure Environment Variables - Vercel Frontend
# Add these to Vercel project environment variables dashboard

# ============================================
# REQUIRED
# ============================================

# Groq API Key for ChemiBot AI Assistant
# Get from: https://console.groq.com/keys
# Must be same as Render backend
GROQ_API_KEY=your_groq_api_key_here

# ============================================
# REQUIRED FOR RENDER + VERCEL INTEGRATION
# ============================================

# URL of your Render backend API
# Format: https://codecure-api.onrender.com
# Or use custom domain: https://api.yourdomain.com
RENDER_API_URL=https://codecure-api.onrender.com

# ============================================
# OPTIONAL - For Vercel-Only Deployment
# ============================================

# PostgreSQL connection string (if using Vercel Database)
# Format: postgres://user:password@host:5432/database
# Only needed if not using Render backend's database
DATABASE_URL=

# ============================================
# OPTIONAL - Performance Settings
# ============================================

# Frontend API timeout in milliseconds
API_TIMEOUT=10000

# Enable analytics (true/false)
ENABLE_ANALYTICS=true

# ============================================
# OPTIONAL - Feature Flags
# ============================================

# Enable ChemiBot chatbot (true/false)
ENABLE_CHATBOT=true

# Enable PDF report generation (true/false)  
ENABLE_PDF_EXPORT=true

# Enable compound history dashboard (true/false)
ENABLE_DASHBOARD=true

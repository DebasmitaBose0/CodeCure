# CodeCure Environment Variables - Render Backend
# Copy these to Render dashboard environment variables

# ============================================
# REQUIRED
# ============================================

# Groq API Key for ChemiBot AI Assistant
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ============================================
# OPTIONAL - Database (for persistent storage)
# ============================================

# PostgreSQL connection string
# Format: postgres://user:password@host:5432/database
# If not set, uses /tmp/codecure.db (ephemeral)
DATABASE_URL=

# ============================================
# REQUIRED FOR RENDER + VERCEL INTEGRATION
# ============================================

# Comma-separated list of allowed origins (domains that can call the API)
# Example: https://codecure-frontend.vercel.app,https://yourdomain.com
# Leave empty or 'localhost' for testing
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================
# OPTIONAL - Performance & Limits
# ============================================

# Request timeout in seconds
REQUEST_TIMEOUT=30

# Maximum compounds in database
MAX_COMPOUNDS_STORED=10000

# ============================================
# OPTIONAL - Logging
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
